name: Build & Commit

on:
  push:
    tags:
      - 'v*'

permissions:
  contents: write

jobs:
  build-pwa:
    runs-on: ubuntu-latest
    continue-on-error: true
    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-node@v3
        with:
          node-version: '22'
      - run: npm install
      - run: npx quasar build -m pwa
      - name: Deploy PWA to Surge
        run: |
          npm install -g surge@0.24.6
          export SURGE_TOKEN=935aec63550df73f541822b03ea28d26
          surge dist/pwa --domain=${{ github.event.repository.name }}.huclin.surge.sh
          surge dist/pwa --domain=${{ github.event.repository.name }}.surge.sh
      - name: Commit PWA build
        run: |
          git config user.name "GitHub Actions"
          git config user.email "actions@github.com"
          git add .
          git commit -m "Build: PWA [tag: ${{ github.ref_name }}]" -m "Co-Authored-By: Warp <agent@warp.dev>" || true
          git push origin HEAD:main
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

